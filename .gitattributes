# Normalize line endings to LF in the repository
* text=auto eol=lf

# Force LF for these file types
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.conf  text eol=lf
*.txt   text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.ico   binary
*.pkl   binary
*.joblib binary
